# textcontrol backend environment variables
# Copy this file to .env and fill in your values

# ── Gemini API (default) ───────────────────────────────────────────────────────
# Get a free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_api_key_here
# AGENT_MODEL=gemini-2.5-flash

# ── Vertex AI (alternative — set USE_VERTEX_AI=true) ───────────────────────────
# USE_VERTEX_AI=true
# VERTEX_PROJECT=your-gcp-project-id
# VERTEX_LOCATION=global

# ── Browser harness ────────────────────────────────────────────────────────────
# Bundled at webapp/browser-harness and found automatically — only set this if
# you keep a checkout somewhere else (use an ABSOLUTE path).
# BROWSER_HARNESS_DIR=/absolute/path/to/browser-harness

# Daemon session name — keeps textcontrol and voicecontrol from fighting over
# the same browser-harness daemon socket if you run both.
BU_NAME=textcontrol
