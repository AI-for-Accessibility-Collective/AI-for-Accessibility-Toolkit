# browsermind-text backend environment variables
# Copy this file to .env and fill in your values

# ── Vertex AI (recommended) ────────────────────────────────────────────────────
USE_VERTEX_AI=true
VERTEX_PROJECT=your-gcp-project-id
VERTEX_LOCATION=global
AGENT_MODEL=gemini-2.5-flash

# ── Gemini API (alternative — set USE_VERTEX_AI=false) ────────────────────────
# USE_VERTEX_AI=false
# GEMINI_API_KEY=your_api_key_here
# AGENT_MODEL=gemini-2.5-flash

# ── Browser harness (path to your browser-harness checkout) ───────────────────
BROWSER_HARNESS_DIR=../../browser-harness
