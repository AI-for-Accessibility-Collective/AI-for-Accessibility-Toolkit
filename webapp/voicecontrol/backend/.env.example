# voicecontrol backend environment variables
# Copy this file to .env and fill in your values

# Get a free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_api_key_here

# Optional: override the model (default: gemini-live-2.5-flash-native-audio)
# DEMO_AGENT_MODEL=gemini-live-2.5-flash-native-audio

# Daemon session name — keeps voicecontrol and textcontrol from fighting over
# the same browser-harness daemon socket if you run both.
BU_NAME=voicecontrol
